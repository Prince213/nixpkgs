@@ -0,0 +1,249 @@
+#include "sysdep.h"
+#include "pe-mdso.h"
+
+#include <stdint.h>
+#include <stdlib.h>
+#include <string.h>
+#include <unistd.h>
+#include <errno.h>
+#include <sys/stat.h>
+
+#include <perk/perk.h>
+#include <mdso/mdso.h>
+
+extern char * program_name;
+extern int    xatexit (void (*)(void));
+
+static char   pe_mdso_tmp_lib_name[] = "/tmp/mdso_XXXXXXXXXXXX";
+static char   pe_perk_tmp_def_name[] = "/tmp/perk_XXXXXXXXXXXX";
+static struct pe_driver_ctx * pe_dctx;
+
+struct pe_mdso_lib
+{
+  dev_t  st_dev;
+  ino_t  st_ino;
+  char   ar_name[24];
+};
+
+struct pe_mdso_lib * pe_mdso_lib_arr;
+struct pe_mdso_lib * pe_mdso_lib_ptr;
+struct pe_mdso_lib * pe_mdso_lib_cap;
+
+static int
+pe_mdso_perk_init (void)
+{
+  char * argv[2];
+
+  if (pe_dctx)
+    return 0;
+
+  argv[0] = program_name;
+  argv[1] = 0;
+
+  return pe_lib_get_driver_ctx (argv, 0, 0, 0, &pe_dctx);
+}
+
+static void
+pe_mdso_cache_unlink (void)
+{
+  struct pe_mdso_lib * pe_mdso;
+
+  for (pe_mdso = pe_mdso_lib_arr; pe_mdso < pe_mdso_lib_ptr; pe_mdso++)
+    unlink (pe_mdso->ar_name);
+}
+
+static int
+pe_mdso_cache_alloc (void)
+{
+  void *  prev;
+  size_t  size;
+  size_t  nlib;
+
+  if (pe_mdso_lib_cap > pe_mdso_lib_ptr)
+    return 0;
+
+  prev = pe_mdso_lib_arr;
+  nlib = pe_mdso_lib_cap - pe_mdso_lib_arr;
+  size = nlib * sizeof (struct pe_mdso_lib);
+
+  pe_mdso_lib_arr = calloc (nlib + 2, sizeof (struct pe_mdso_lib));
+  if (!pe_mdso_lib_arr)
+    return -1;
+
+  if (!prev)
+    xatexit (pe_mdso_cache_unlink);
+
+  memcpy (pe_mdso_lib_arr, prev, size);
+
+  pe_mdso_lib_ptr = &pe_mdso_lib_arr[nlib];
+  pe_mdso_lib_cap = &pe_mdso_lib_arr[nlib + 2];
+
+  return 0;
+}
+
+const char *
+pe_mdso_input_name (const char * input_name)
+{
+  int    fdin;
+  int    fdout;
+  char * libname;
+  char * argv[8];
+
+  struct stat              st;
+  struct pe_mdso_lib *     pe_mdso;
+  struct pe_unit_ctx *     pe_uctx;
+  struct pe_fd_ctx         pe_fdctx;
+  struct mdso_driver_ctx * mdso_dctx;
+
+  if (pe_mdso_perk_init () < 0)
+    return 0;
+
+  if ((fdin = open (input_name, O_RDONLY)) < 0)
+    return input_name;
+
+  if (fstat (fdin, &st) < 0)
+    {
+      close (fdin);
+      return 0;
+    }
+
+  for (pe_mdso = pe_mdso_lib_arr; pe_mdso < pe_mdso_lib_ptr; pe_mdso++)
+    {
+      if ((pe_mdso->st_dev == st.st_dev) && (pe_mdso->st_ino == st.st_ino))
+	{
+	  close (fdin);
+	  return pe_mdso->ar_name;
+	}
+    }
+
+  if (pe_lib_get_unit_ctx (pe_dctx, input_name, &pe_uctx) < 0)
+    {
+      close (fdin);
+      return input_name;
+    }
+
+  if (pe_uctx->x_armeta)
+    {
+      close (fdin);
+      pe_lib_free_unit_ctx (pe_uctx);
+      return input_name;
+    }
+
+  switch (pe_uctx->x_meta->m_subtype)
+    {
+    case PE_SUBTYPE_DLL:
+    case PE_SUBTYPE_EXE:
+      break;
+
+    default:
+      close (fdin);
+      pe_lib_free_unit_ctx (pe_uctx);
+      return input_name;
+    }
+
+  switch (pe_uctx->x_meta->m_abi)
+    {
+    case PE_ABI_PE32:
+      argv[1] = "-m32";
+      break;
+
+    case PE_ABI_PE64:
+      argv[1] = "-m64";
+      break;
+
+    default:
+      close (fdin);
+      pe_lib_free_unit_ctx (pe_uctx);
+      return 0;
+    }
+
+  if (pe_lib_get_driver_fdctx (pe_dctx, &pe_fdctx) < 0)
+    {
+      close (fdin);
+      pe_lib_free_unit_ctx (pe_uctx);
+      pe_output_error_vector (pe_dctx);
+      return 0;
+    }
+
+  memset (&pe_perk_tmp_def_name[10], 'X', 12);
+  memset (&pe_mdso_tmp_lib_name[10], 'X', 12);
+
+  pe_fdctx.fdout = mkstemp (pe_perk_tmp_def_name);
+  if (pe_fdctx.fdout < 0)
+    {
+      close (fdin);
+      pe_lib_free_unit_ctx (pe_uctx);
+      return 0;
+    }
+
+  if (pe_lib_set_driver_fdctx (pe_dctx, &pe_fdctx) < 0)
+    {
+      close (fdin);
+      pe_lib_free_unit_ctx (pe_uctx);
+      return 0;
+    }
+
+  if (pe_output_export_symbols (pe_uctx->x_meta) < 0)
+    {
+      close (fdin);
+      pe_lib_free_unit_ctx (pe_uctx);
+      pe_output_error_vector (pe_dctx);
+      return 0;
+    }
+
+  close (fdin);
+  pe_lib_free_unit_ctx (pe_uctx);
+
+  libname = strrchr (input_name, '/');
+  if (libname)
+    libname++;
+  else
+    {
+      libname = strrchr (input_name, '\\');
+      if (libname)
+	libname++;
+      else
+	libname = (char *) input_name;
+    }
+
+  if (pe_mdso_cache_alloc () < 0)
+    return 0;
+
+  fdout = mkstemp (pe_mdso_tmp_lib_name);
+  if (fdout < 0)
+    return 0;
+
+  argv[0] = program_name;
+  argv[2] = "--libname";
+  argv[3] = libname;
+  argv[4] = "--implib";
+  argv[5] = pe_mdso_tmp_lib_name;
+  argv[6] = pe_perk_tmp_def_name;
+  argv[7] = 0;
+
+  if (mdso_lib_get_driver_ctx (argv, 0, 0, 0, &mdso_dctx) < 0)
+    {
+      close (fdout);
+      return 0;
+    }
+
+  if (mdso_gen_implib_archive (mdso_dctx) < 0)
+    {
+      close (fdout);
+      mdso_output_error_vector (mdso_dctx);
+      mdso_lib_free_driver_ctx (mdso_dctx);
+      return 0;
+    }
+
+  strcpy (pe_mdso_lib_ptr->ar_name, pe_mdso_tmp_lib_name);
+
+  pe_mdso_lib_ptr->st_dev = st.st_dev;
+  pe_mdso_lib_ptr->st_ino = st.st_ino;
+  pe_mdso_lib_ptr++;
+
+  unlink (pe_perk_tmp_def_name);
+  mdso_lib_free_driver_ctx (mdso_dctx);
+  close (fdout);
+
+  return pe_mdso_tmp_lib_name;
+}
