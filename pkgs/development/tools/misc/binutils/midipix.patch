+#ifdef PE_TARGET_MDSO
+void
+pe_dll_generate_dsolib (def_file *def,
+			const char **expsyms,
+			const char *dsolib_file_name,
+			const char *loader_path,
+			unsigned char bits)
+{
+  char *mdso_exe_path;
+  char *slash;
+  char *mark;
+  FILE *fout;
+  char *argv[10];
+  int fd[2];
+  int pid;
+  int rpid;
+  int ecode;
+  int i;
+
+  if ((bits != 32) && (bits != 64))
+    {
+      fprintf (stderr, "%s: internal error (bits == %d).\n",
+	       program_name, bits);
+      xexit (EXIT_FAILURE);
+    }
+
+  mdso_exe_path = calloc (1, strlen (program_name) + strlen ("mdso") + 1);
+  if (!mdso_exe_path)
+    {
+      fprintf (stderr, "%s: cannot allocate mdso_exe_path buffer.\n",
+	       program_name);
+      xexit (EXIT_FAILURE);
+    }
+
+  strcpy (mdso_exe_path, program_name);
+
+  slash = strrchr (mdso_exe_path, '/');
+  if (slash)
+    slash++;
+  else
+    slash = mdso_exe_path;
+
+  mark = strrchr (slash, '-');
+  if (mark)
+    mark++;
+  else
+    mark = slash;
+
+  sprintf (mark, "%s", "mdso");
+
+  if (pipe (fd))
+    {
+      fprintf (stderr, "%s: cannot create a pipe.\n", program_name);
+      xexit (EXIT_FAILURE);
+    }
+
+  fout = fdopen (fd[1], "a");
+  if (!fout)
+    {
+      fprintf (stderr, "%s: pipe fdopen failed.\n", program_name);
+      xexit (EXIT_FAILURE);
+    }
+
+  pid = fork ();
+  if (pid < 0)
+    {
+      fprintf (stderr, "%s: fork failed.\n", program_name);
+      xexit (EXIT_FAILURE);
+    }
+
+  if (pid == 0)
+    {
+      argv[0] = mdso_exe_path;
+      argv[1] = (bits == 64) ? "-m64" : "-m32";
+      argv[2] = "--implib";
+      argv[3] = (char *) dsolib_file_name;
+      argv[4] = "--libname";
+      argv[5] = (def->name) ? def->name : (char *) dll_symname;
+
+      if (loader_path)
+	{
+	  argv[6] = "--libpath";
+	  argv[7] = (char *) loader_path;
+	  argv[8] = "-";
+	  argv[9] = 0;
+	}
+      else
+	{
+	  argv[6] = "-";
+	  argv[7] = 0;
+	}
+
+      fclose (fout);
+      close (fd[1]);
+      close (0);
+
+      if (dup (fd[0]) == 0)
+	execvp (mdso_exe_path, argv);
+
+      exit (EXIT_FAILURE);
+    }
+
+  free (mdso_exe_path);
+
+  if (expsyms)
+    {
+      for (; *expsyms;)
+	{
+	  if (fprintf (fout, "%s\n", *expsyms++) < 0)
+	    {
+	      fprintf (stderr, "%s: pipe write operation failed.\n",
+		       program_name);
+	      xexit (EXIT_FAILURE);
+	    }
+	}
+    }
+  else
+    {
+      for (i = 0; i < def->num_exports; i++)
+	{
+	  if (!(pe_def_file->exports[i].flag_private))
+	    {
+	      if (fprintf (fout, "%s\n", def->exports[i].name) < 0)
+		{
+		  fprintf (stderr, "%s: pipe write operation failed.\n",
+			   program_name);
+		  xexit (EXIT_FAILURE);
+		}
+	    }
+	}
+    }
+
+  if (fflush (fout) < 0)
+    {
+      fprintf (stderr, "%s: pipe fflush operation failed.\n", program_name);
+      xexit (EXIT_FAILURE);
+    }
+
+  fclose (fout);
+  close (fd[0]);
+
+  rpid = waitpid (pid, &ecode, 0);
+  if (rpid < 0)
+    {
+      fprintf (stderr, "%s: waitpid operation failed.\n", program_name);
+      xexit (EXIT_FAILURE);
+    }
+
+  if (rpid != pid)
+    {
+      fprintf (stderr, "%s: waitpid returned an unexpected pid.\n",
+	       program_name);
+      xexit (EXIT_FAILURE);
+    }
+
+  if (!(WIFEXITED (ecode)))
+    {
+      fprintf (stderr,
+	       "%s: waitpid reported abnormal child process termination.\n",
+	       program_name);
+      xexit (EXIT_FAILURE);
+    }
+
+  if (WEXITSTATUS (ecode))
+    {
+      fprintf (stderr, "%s: the child process returned an error.\n",
+	       program_name);
+      xexit (EXIT_FAILURE);
+    }
+}
