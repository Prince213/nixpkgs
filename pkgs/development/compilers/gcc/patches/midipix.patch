+
+/* ---------- DLL import ---------- */
+
+int
+midipix_symbol_ref_dllimport_p (rtx symbol)
+{
+  tree decl = SYMBOL_REF_DECL (symbol);
+
+  if (!decl || !TREE_PUBLIC (decl) || flag_assume_static_linking)
+    return 0;
+
+  return (DECL_VISIBILITY (decl) == VISIBILITY_DEFAULT)
+	 || !DECL_VISIBILITY_SPECIFIED (decl);
+}
+
+
+/* ---------- integer assembly with GOT ---------- */
+
+bool
+midipix_asm_assemble_integer (rtx x, unsigned int size, int aligned_p)
+{
+  rtx xref, xoff;
+  tree decl;
+  section *sect;
+  const char *name;
+  const char *ptrsize;
+  const char *secname;
+  const char *sortname;
+  char namebuf[2048];
+  bool is_extern_ref;
+  int visibility;
+
+  if (flag_assume_static_linking)
+    return default_assemble_integer (x, size, aligned_p);
+
+  if (GET_CODE (x) == CONST)
+    {
+      xoff = XEXP (x, 0);
+      xref = XEXP (xoff, 0);
+      xoff = XEXP (xoff, 1);
+    }
+  else
+    {
+      xref = x;
+      xoff = NULL_RTX;
+    }
+
+  decl = NULL_TREE;
+  is_extern_ref = (GET_CODE (xref) == SYMBOL_REF
+		   && (decl = SYMBOL_REF_DECL (xref)) != NULL_TREE
+		   && DECL_P (decl)
+		   && DECL_EXTERNAL (decl)
+		   && TREE_PUBLIC (decl));
+
+  /* C++ typeinfo.  */
+  is_extern_ref |= (GET_CODE (xref) == SYMBOL_REF
+		     && SYMBOL_REF_DECL (xref) == NULL_TREE);
+
+  visibility = (is_extern_ref && decl
+		&& DECL_VISIBILITY_SPECIFIED (decl))
+    ? DECL_VISIBILITY (decl)
+    : VISIBILITY_DEFAULT;
+
+  if (!is_extern_ref || visibility != VISIBILITY_DEFAULT)
+    return default_assemble_integer (x, size, aligned_p);
+
+  name = XSTR (xref, 0);
+  ptrsize = TARGET_64BIT ? winnt_ptrsize_quad : winnt_ptrsize_long;
+
+  if (in_section == data_section)
+    sect = data_section;
+  else if (in_section == readonly_data_section)
+    sect = readonly_data_section;
+  else if (in_section && decl)
+    sect = get_variable_section (decl, false);
+  else if (xoff)
+    sect = data_section;
+  else
+    sect = NULL;
+
+  fputs ("1:\n", asm_out_file);
+
+  fputs ("\t", asm_out_file);
+  fputs (ptrsize, asm_out_file);
+  fputs ("\t0", asm_out_file);
+
+  if (xoff && INTVAL (xoff) < 0)
+    fprintf (asm_out_file, HOST_WIDE_INT_PRINT_DEC, INTVAL (xoff));
+  else if (xoff && INTVAL (xoff))
+    {
+      fputs ("+", asm_out_file);
+      fprintf (asm_out_file, HOST_WIDE_INT_PRINT_DEC, INTVAL (xoff));
+    }
+
+  if (!in_section)
+    gcc_unreachable ();
+
+  switch (SECTION_STYLE (in_section))
+    {
+    case SECTION_NAMED:
+      secname = in_section->named.name;
+      break;
+
+    case SECTION_UNNAMED:
+      if (in_section->common.flags & SECTION_WRITE)
+	secname = ".data";
+      else
+	secname = ".rdata";
+      break;
+
+    default:
+      gcc_unreachable ();
+    }
+
+  sortname = strchr (secname, '$');
+  if (!sortname)
+    sortname = secname;
+  else if ((size_t)(sortname - secname) >= sizeof (namebuf))
+    gcc_unreachable ();
+  else
+    {
+      memcpy (namebuf, secname, sortname - secname);
+      namebuf[sortname - secname] = '\0';
+      sortname = namebuf;
+    }
+
+  /* .gotrefs section.  */
+  fputs ("\n\n", asm_out_file);
+  fputs (GAS_SECTION, asm_out_file);
+  fputs (GOTREFS_SECTION_NAME "$", asm_out_file);
+  fputs (sortname, asm_out_file);
+  fputs ("\n", asm_out_file);
+
+  fprintf (asm_out_file, "\t.rva\t%s\n", secname);
+  fprintf (asm_out_file, "\t.long\t1b - %s\n", secname);
+
+  fputs ("\t.rva\t__imp_", asm_out_file);
+  assemble_name (asm_out_file, name);
+  fputs ("\n\n", asm_out_file);
+
+  midipix_asm_reestablish_section (asm_out_file, sect);
+
+  return true;
+}
