+/* ---------- object / function declarations ---------- */
+
+void
+midipix_asm_declare_object_name (FILE *f, const char *name, tree decl)
+{
+  mingw_pe_maybe_record_exported_symbol (decl, name, 1);
+  ASM_OUTPUT_LABEL (f, name);
+}
+
+void
+midipix_asm_drectve_section (void)
+{
+  in_section = NULL;
+  fprintf (asm_out_file, "%s%s\n", GAS_SECTION, DRECTVE_SECTION_NAME);
+}
+
+int
+midipix_target_use_local_thunk_alias (tree decl)
+{
+  return !DECL_ONE_ONLY (decl);
+}
+
+void
+midipix_asm_output_external (FILE *f ATTRIBUTE_UNUSED,
+			     tree decl,
+			     const char *name)
+{
+  if (TREE_CODE (decl) == FUNCTION_DECL)
+    i386_pe_record_external_function (decl, name);
+}
+
+void
+midipix_asm_output_external_libcall (FILE *f, rtx fn)
+{
+  mingw_pe_declare_type (f, XSTR (fn, 0), true, true);
+}
+
+void
+midipix_asm_output_def_from_decls (FILE *f, tree decl, tree target)
+{
+  const char *sym = IDENTIFIER_POINTER (DECL_ASSEMBLER_NAME (decl));
+
+  mingw_pe_maybe_record_exported_symbol (decl, sym, 0);
+
+  if (TREE_CODE (decl) == FUNCTION_DECL)
+    mingw_pe_declare_type (f, sym, TREE_PUBLIC (decl), true);
+
+  ASM_OUTPUT_DEF (f, sym, IDENTIFIER_POINTER (target));
+
+  if (!DECL_WEAK (decl))
+    midipix_asm_output_got_entry (f, sym, decl, NULL);
+}
