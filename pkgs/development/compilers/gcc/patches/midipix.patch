+void
+midipix_seh_hook__pe_seh_init (FILE *f)
+{
+  if (TARGET_SEH_WINNT)
+    i386_pe_seh_init (f);
+}
+
+void
+midipix_seh_hook__pe_seh_end_prologue (FILE *f)
+{
+  if (TARGET_SEH_WINNT)
+    i386_pe_seh_end_prologue (f);
+}
+
+void
+midipix_seh_hook__pe_seh_unwind_emit (FILE *f, rtx_insn *insn)
+{
+  if (TARGET_SEH_WINNT)
+    i386_pe_seh_unwind_emit (f, insn);
+}
+
+void
+midipix_seh_hook__pe_seh_emit_except_personality (rtx personality)
+{
+  fputs ("\t.seh_handler\t", asm_out_file);
+  fputs (".", asm_out_file);
+  output_addr_const (asm_out_file, personality);
+  fputs (", @unwind, @except\n", asm_out_file);
+}
