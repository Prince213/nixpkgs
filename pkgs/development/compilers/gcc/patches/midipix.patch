+/* Common specs required by winnt.cc when compiled for midipix.
+   These must have external linkage (extern) because winnt.cc is compiled
+   as a separate translation unit (midipix_winnt_common.o) and references
+   them via the extern declarations in midipix_winnt_common.h.  In C++,
+   const at namespace scope defaults to internal linkage.  */
+extern const int TARGET_NOP_FUN_DLLIMPORT = 0;
+extern const int use_pe_aligned_common = 1;
+extern const int flag_writable_rel_rdata = 0;
+
+static const char winnt_ptrsize_long[] = ".long";
+static const char winnt_ptrsize_quad[] = ".quad";
+
+#define TARGET_SEH_WINNT   (TARGET_SEH && TARGET_NT64)
+#define TARGET_SEH_MIDIPIX (TARGET_SEH && TARGET_NT32)
+
+
+/* ---------- debugging ---------- */
+
+unsigned int
+midipix_dbx_get_register_number (unsigned int n)
+{
+  if (TARGET_NT64)
+    return debugger64_register_map[n];
+  else if (dwarf_debuginfo_p ())
+    return svr4_debugger_register_map[n];
+  else
+    return debugger_register_map[n];
+}
+
+unsigned int
+midipix_dbx_get_dwarf_frame_register_number (unsigned int n)
+{
+  if (TARGET_NT64)
+    return debugger64_register_map[n];
+  else
+    return svr4_debugger_register_map[n];
+}
+
+void
+midipix_asm_output_dwarf_offset (FILE *f, unsigned size,
+				 const char *label,
+				 section *sect ATTRIBUTE_UNUSED)
+{
+  if (size == 4 || size == 8)
+    {
+      fputs ("\t.secrel32\t", f);
+      assemble_name (f, label);
+      if (size == 8)
+	fputs ("\n\t.long\t0", f);
+    }
+  else
+    gcc_unreachable ();
+}
+
+
+/* ---------- assembler labels ---------- */
+
+void
+midipix_asm_output_label_ref (FILE *f, const char *name)
+{
+  if (*name != FASTCALL_PREFIX)
+    fputs (user_label_prefix, f);
+  fputs (name, f);
+}
+
+void
+midipix_asm_generate_internal_label (char *buf, const char *prefix,
+				     unsigned long number)
+{
+  sprintf (buf, "*%s%s%ld", LOCAL_LABEL_PREFIX, prefix, (long) number);
+}
