+
+/* ---------- unwind info type ---------- */
+
+enum unwind_info_type
+midipix_except_unwind_info (struct gcc_options *opts ATTRIBUTE_UNUSED)
+{
+  return UI_SEH;
+}
+
+
+/* ---------- function sections ---------- */
+
+section *
+midipix_i386_pe_function_section (tree decl, enum node_frequency freq,
+				  bool startup, bool exit_p)
+{
+  const char *fname;
+  bool weak;
+
+  fname = IDENTIFIER_POINTER (DECL_ASSEMBLER_NAME (decl));
+  weak = (DECL_DLLIMPORT_P (decl) && DECL_WEAK (decl));
+
+  if (weak)
+    {
+      char *secname;
+      section *s;
+      size_t len = strlen (fname) + 7;
+
+      secname = (char *) xmalloc (len);
+      snprintf (secname, len, ".text$%s", fname);
+      s = get_named_section (decl, secname, 1);
+      free (secname);
+      return s;
+    }
+
+  return NULL;
+}
+
+
+/* ---------- common output ---------- */
+
+void
+midipix_i386_pe_asm_output_aligned_decl_common (FILE *stream, tree decl,
+						const char *name,
+						HOST_WIDE_INT size,
+						HOST_WIDE_INT align)
+{
+  i386_pe_asm_output_aligned_decl_common (stream, decl, name, size, align);
+}
+
+
+/* ---------- function boundaries ---------- */
+
+void
+midipix_i386_pe_start_function (FILE *f, const char *name, tree decl)
+{
+  i386_pe_start_function (f, name, decl);
+}
+
+void
+midipix_i386_pe_end_function (FILE *f, const char *name, tree decl)
+{
+  if (cfun->is_thunk)
+    {
+      midipix_asm_output_got_entry (f, name, decl, NULL);
+      return;
+    }
+
+  i386_pe_end_function (f, name, decl);
+
+  if (decl && !DECL_WEAK (decl))
+    midipix_asm_output_got_entry (f, name, decl, NULL);
+}
+
+
+/* ---------- weak symbols ---------- */
+
+void
+midipix_i386_pe_asm_weaken_decl (FILE *f, tree decl,
+				 const char *name,
+				 const char *alias ATTRIBUTE_UNUSED)
+{
+  midipix_asm_output_got_entry (f, name, decl, NULL);
+  fputs ("\t.weak\t", f);
+  assemble_name (f, name);
+  fputs ("\n", f);
+}
+
+void
+midipix_i386_pe_asm_weaken_label (FILE *f, const char *name)
+{
+  midipix_i386_pe_asm_weaken_decl (f, NULL_TREE, name, NULL);
+}
